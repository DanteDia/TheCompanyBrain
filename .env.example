# ─── Anthropic ───────────────────────────────────────────────────────────────
# API key from console.anthropic.com (NOT the same as Claude Code Pro subscription).
# Required server-side for the Q&A agent, post-interview extractor, and router.
ANTHROPIC_API_KEY=sk-ant-...

# Models — defaults below match the spec V2; override only for testing.
MODEL_QA=claude-opus-4-7
MODEL_QA_FALLBACK=claude-opus-4-6
MODEL_EXTRACTOR=claude-opus-4-7
MODEL_INTERVIEW=claude-sonnet-4-6
MODEL_ROUTER=claude-haiku-4-5

# ─── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...
# Anon key for the frontend only.
SUPABASE_ANON_KEY=eyJhbGc...

# ─── Voyage (embeddings) ─────────────────────────────────────────────────────
VOYAGE_API_KEY=pa-...
VOYAGE_MODEL=voyage-3-large

# ─── Retell.ai (voice agent) ─────────────────────────────────────────────────
RETELL_API_KEY=key_...
RETELL_AGENT_ID=
# Webhook URL (filled in after Render deploy):
RETELL_WEBHOOK_URL=https://company-brain-backend.onrender.com/retell/webhook

# ─── Twilio (telephony for Retell) ───────────────────────────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM_NUMBER=+5491100000000

# ─── Google Calendar (service account) ───────────────────────────────────────
# Path to the GCP service account JSON, OR the JSON contents inline (Render env).
GCP_SERVICE_ACCOUNT_JSON_PATH=./gcp-service-account.json
GCP_SERVICE_ACCOUNT_JSON=
# Email of an admin in the customer's Google Workspace that the SA impersonates:
CALENDAR_ORGANIZER_EMAIL=admin@bind.com.ar

# ─── App config ──────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
DEFAULT_TIMEZONE=America/Argentina/Buenos_Aires
DEFAULT_ORG_ID=banco_demo

# Frontend → backend URL (used by Next.js):
NEXT_PUBLIC_API_URL=http://localhost:8000
